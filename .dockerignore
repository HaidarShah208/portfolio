############################################################
# Keep the build context small, fast, and free of secrets
############################################################

# Dependencies (installed inside the image)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs (generated during `next build`)
.next/
out/
build/
dist/
.vercel/

# Git / VCS
.git/
.gitignore
.gitattributes

# Env & secrets — inject at runtime / build-arg, never bake into layers
.env
.env.*
!.env.example

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# Docs & misc (not needed to build)
*.md
docs/
LICENSE*
README*

# Docker / compose (not needed inside the image)
Dockerfile*
.dockerignore
compose.yaml
compose.yml
docker-compose*.yml
docker-compose*.yaml

# CI / tooling metadata
.github/
.gitlab-ci.yml
.cursor/
.cursorrules
AGENTS.md
coverage/
*.tsbuildinfo
.eslintcache
.turbo/
.cache/
