# Google Gemini API key for the AI Portfolio Assistant (server-side only, never exposed to the browser).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key

# Optional: override the model used by the assistant (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: production site URL used for SEO metadata, canonical, sitemap and robots.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
